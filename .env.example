# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME"

# =============================================================================
# APP
# =============================================================================
APP_URL="http://localhost:3000"

# =============================================================================
# EMAIL / RESEND
# =============================================================================
# Isi dengan API key dari dashboard Resend.
# Kalau kosong, sistem akan skip pengiriman email dan hanya menampilkan log server.
RESEND_API_KEY=""

# Untuk testing awal Resend, bisa pakai:
# EMAIL_FROM="EduBidan <onboarding@resend.dev>"
#
# Untuk production, gunakan domain yang sudah diverifikasi di Resend:
# EMAIL_FROM="EduBidan <noreply@domainkamu.com>"
EMAIL_FROM="EduBidan <onboarding@resend.dev>"

AUTH_SESSION_SECRET="edubidan-local-session-secret-minimum-32-character"